{
  "name": "gemini-whatsapp-bot",
  "version": "2.1.1",
  "description": "WhatsApp AI assistant powered by Google Gemini (complex tasks) and Groq/Llama (simple chat). Image generation, file creation, reminders, scheduling, and more.",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "server": "node server.js",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "postinstall": "electron-builder install-app-deps || echo 'Skipping electron-builder (headless mode)'"
  },
  "author": "Lewi Verdatama",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@whiskeysockets/baileys": "^6.7.17",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "googleapis": "^171.4.0",
    "groq-sdk": "^0.37.0",
    "link-preview-js": "^3.0.5",
    "pdfkit": "^0.17.2",
    "pino": "^9.6.0",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.gemini.whatsapp-bot",
    "productName": "Gemini WhatsApp Bot",
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null,
      "installerHeaderIcon": null,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "Gemini-WhatsApp-Bot-Portable.exe"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ]
  }
}