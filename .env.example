# Required: Google Gemini API keys (comma-separated for rotation)
# Get free keys at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_1,your_gemini_key_2,your_gemini_key_3

# Optional: Groq API key for lightweight simple-chat routing (free, no credit card)
# Simple greetings/chitchat → Groq (Llama 3.3 70B) — saves Gemini quota
# Complex tasks (files, images, maps, etc.) always go to Gemini regardless
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Optional: Pollinations AI key for image generation (free)
# Get at: https://enter.pollinations.ai
POLLINATIONS_API_KEY=sk_your_pollinations_key_here

# Optional: WhatsApp phone number for pairing code fallback (digits only, with country code)
WHATSAPP_PHONE_NUMBER=628123456789

# Optional: Whitelist for /healthcheck command (comma-separated phone numbers with country code)
# Only numbers listed here can trigger health checks. Leave empty to disable entirely.
# Example: HEALTH_CHECK_WHITELIST=628111222333,628444555666
HEALTH_CHECK_WHITELIST=

# Timezone (default: system timezone)
TZ=Asia/Jakarta
