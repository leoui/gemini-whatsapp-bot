{
    "name": "whatsapp-bot-manager",
    "version": "1.2.6",
    "description": "macOS configuration manager for Gemini WhatsApp Bot — SSH-based VPS management",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron .",
        "build": "electron-builder --mac"
    },
    "author": "Lewi Verdatama",
    "license": "MIT",
    "dependencies": {
        "electron-store": "^8.2.0",
        "ssh2": "^1.16.0"
    },
    "devDependencies": {
        "electron": "^33.3.1",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "appId": "com.leoui.whatsapp-bot-manager",
        "productName": "Bot Manager",
        "mac": {
            "category": "public.app-category.utilities",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                }
            ],
            "icon": null
        },
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!dist/**",
            "!node_modules/electron/**"
        ]
    }
}